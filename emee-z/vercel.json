{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "env": {
    "DATABASE_URL": "@DATABASE_URL",
    "JWT_SECRET": "@JWT_SECRET",
    "EVOLUTION_API_KEY": "@EVOLUTION_API_KEY",
    "NODE_ENV": "production"
  },
  "functions": {
    "frontend/api/**/*.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(?<path>.*)",
      "dest": "frontend/api/$path"
    }
  ]
}
